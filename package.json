{
  "name": "booru-mobile-safari",
  "version": "1.2.2",
  "private": true,
  "description": "Mobile-only userscript for Yande.re, Konachan, Danbooru and Gelbooru.",
  "author": "asadahimeka, aiza2a",
  "license": "MIT",
  "main": "dist/booru-mobile-safari.user.js",
  "scripts": {
    "dev": "vite",
    "release": "node scripts/release.mjs",
    "build": "vite build",
    "postbuild": "node scripts/postbuild.mjs",
    "lint": "eslint src --ext .ts,.vue",
    "verify:dates": "node scripts/verify-site-date-routes.mjs && node scripts/verify-date-route-parser.mjs && node scripts/verify-moebooru-html.mjs && node scripts/verify-gelbooru-recent.mjs",
    "verify:gelbooru-live": "node scripts/verify-live-gelbooru-recent.mjs",
    "preinstall": "npx -y only-allow pnpm"
  },
  "dependencies": {
    "@himeka/booru": "workspace:2.7.7",
    "@himeka/masonry-css": "workspace:1.0.3",
    "@himeka/masonry-true": "workspace:1.0.5",
    "@himeka/virtual-waterfall": "workspace:1.0.8",
    "@vueuse/core": "11.0.3",
    "date-fns": "3.6.0",
    "vue": "2.7.16",
    "vue-i18n": "8.28.2",
    "vuetify": "2.7.2"
  },
  "devDependencies": {
    "@antfu/eslint-config-vue": "0.27.0",
    "@himeka/release": "workspace:0.0.1",
    "@himeka/vite-userscript": "workspace:1.2.1",
    "@mdi/js": "7.4.47",
    "@types/node": "20.10.6",
    "@types/tampermonkey": "5.0.2",
    "@vitejs/plugin-vue2": "1.1.2",
    "eslint": "8.26.0",
    "typescript": "4.8.4",
    "vite": "2.9.5",
    "vue-template-compiler": "2.7.16"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  }
}
